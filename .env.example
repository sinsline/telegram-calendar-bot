# Environment Configuration Template
# Copy this to .env and fill in your actual values

# ===================================
# REQUIRED SETTINGS
# ===================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ===================================  
# GOOGLE CALENDAR INTEGRATION (OPTIONAL)
# ===================================

# Google Calendar ID (usually your email or calendar-specific ID)
GOOGLE_CALENDAR_ID=your@gmail.com

# Path to Google credentials JSON file
GOOGLE_CREDENTIALS_FILE=./credentials.json

# Google OAuth scopes (comma-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar

# ===================================
# BOT BEHAVIOR SETTINGS
# ===================================

# Rate limiting per user (requests per minute)
RATE_LIMIT_PER_MINUTE=20

# Rate limiting per user (requests per hour)
RATE_LIMIT_PER_HOUR=200

# Rate limiting per user (requests per day)  
RATE_LIMIT_PER_DAY=1000

# Default timezone for events
CALENDAR_TIMEZONE=Europe/Berlin

# ===================================
# LOGGING CONFIGURATION
# ===================================

# Main log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Google API specific log level
GOOGLE_LOG_LEVEL=WARNING

# Whisper (speech recognition) log level
WHISPER_LOG_LEVEL=WARNING

# OCR (Tesseract) log level
OCR_LOG_LEVEL=WARNING

# ===================================
# NLP SERVICE CONFIGURATION
# ===================================

# Supported languages (comma-separated: ru,de,en)
NLP_SUPPORTED_LANGUAGES=ru,de,en

# Confidence threshold for NLP parsing (0.0-1.0)
NLP_CONFIDENCE_THRESHOLD=0.7

# Default event duration in minutes when not specified
NLP_DEFAULT_EVENT_DURATION=60

# ===================================
# OCR SERVICE CONFIGURATION  
# ===================================

# OCR languages (plus-separated: rus+eng+deu)
OCR_LANGUAGES=rus+eng+deu

# OCR DPI for image processing
OCR_DPI=300

# Maximum image size in pixels (4096 = 4K)
OCR_IMAGE_MAX_SIZE=4096

# Maximum image file size in bytes (10MB)
OCR_MAX_FILE_SIZE=10485760

# ===================================
# SPEECH SERVICE CONFIGURATION
# ===================================

# Whisper model (tiny, base, small, medium, large)
# tiny = fastest, large = most accurate
SPEECH_MODEL=base

# Maximum audio file size in bytes (25MB)
SPEECH_MAX_FILE_SIZE=26214400

# Speech processing timeout in seconds
SPEECH_TIMEOUT=60

# ===================================
# ADVANCED SETTINGS
# ===================================

# Python settings
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# Environment (development, production)
ENVIRONMENT=production

# Data directory for persistent storage
DATA_DIR=./data

# Logs directory
LOGS_DIR=./logs

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# ===================================
# OPTIONAL DATABASE (if implementing)
# ===================================

# Database URL (for future use)
# DATABASE_URL=sqlite:///./data/bot.db
# DATABASE_URL=postgresql://user:password@localhost/telegram_bot

# ===================================
# SECURITY SETTINGS
# ===================================

# Secret key for internal operations (generate random string)
SECRET_KEY=your-secret-key-here-please-change-this

# Allow only specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
ALLOWED_USER_IDS=

# Enable debug mode (only for development)
DEBUG_MODE=False

# ===================================
# MONITORING & PERFORMANCE
# ===================================

# Enable Prometheus metrics (if implemented)
ENABLE_METRICS=False

# Metrics server port
METRICS_PORT=8080

# Enable health check endpoint  
ENABLE_HEALTH_CHECK=True

# Health check port
HEALTH_CHECK_PORT=8081

# ===================================
# EXAMPLE VALUES (DEVELOPMENT)
# ===================================
# Uncomment and modify for development setup:

# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz_development
# GOOGLE_CALENDAR_ID=test@gmail.com
# LOG_LEVEL=DEBUG
# ENVIRONMENT=development
# DEBUG_MODE=True
# RATE_LIMIT_PER_MINUTE=100
# SPEECH_MODEL=tiny